# 桌面端构建、签名和更新相关环境变量示例。
# 这些值通常在 CI 或发布机上设置，不属于用户本机偏好。

# macOS Developer ID 签名身份。
MACOS_SIGN_IDENTITY="Developer ID Application: Example Team (TEAMID1234)"

# Apple notarize 本机凭据名称，需先通过 xcrun notarytool store-credentials 创建。
NOTARY_PROFILE=example-notary-profile

# macOS 自动更新校验签名时使用的 Team ID。
MACOS_TEAM_ID=TEAMID1234

# 当前桌面端更新清单地址。
UPDATE_MANIFEST_URL=https://updates.example.com/console/stable/latest.json

# 当前构建号；同一 version 下必须持续递增。
BUNDLE_VERSION=12

# 桌面端 OIDC 认证配置。ZITADEL 可作为标准 OIDC Provider 接入。
# Native/Public Application 的 redirect URI 模板。端口 0 会在登录时替换为实际监听端口。
# ZITADEL 必须允许此 Native loopback redirect URI 的实际端口。
OIDC_ISSUER_URL=https://id.example.com
OIDC_CLIENT_ID=console-native-client-id
OIDC_SCOPES="openid profile email offline_access"
OIDC_REDIRECT_URI=http://127.0.0.1:0/auth/callback
