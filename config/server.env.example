# 服务端运行时环境变量示例。
# 环境变量没有项目名前缀；双下划线表示 TOML 层级。

SERVER__HOST=0.0.0.0
SERVER__PORT=8080
DATABASE__URL=postgres://nexora:replace-me@postgres:5432/nexora
DATABASE__MAX_CONNECTIONS=20
SETUP__SECRET=replace-with-a-long-random-setup-secret
OIDC__ISSUER_URL=https://id.example.com
OIDC__AUDIENCE=replace-with-api-application-client-id
OIDC__PROJECT_ID=replace-with-zitadel-project-id
OIDC__PERSONAL_ACCESS_TOKEN=replace-with-zitadel-service-account-pat
